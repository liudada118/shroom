{
  "name": "jqtools2",
  "version": "1.0.1",
  "description": "JQ 压力传感器桌面工具",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dev:static": "cross-env USE_STATIC=1 electron .",
    "build:client": "npm --prefix client install && npm --prefix client run build && node scripts/sync-client-build.js",
    "build:win": "npm run build:client && electron-builder -w",
    "build:mac": "npm run build:client && electron-builder -m",
    "install:all": "npm install && cd client && npm install",
    "postinstall": "electron-builder install-app-deps || echo [postinstall] skip native rebuild",
    "rebuild:native": "electron-builder install-app-deps"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0-beta.3",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "csv-parser": "^3.2.0",
    "csv-writer": "^1.6.0",
    "express": "^5.1.0",
    "multer": "^2.1.1",
    "serialport": "^13.0.0",
    "sqlite3": "5.1.6",
    "systeminformation": "^5.27.1",
    "ws": "^8.18.2"
  },
  "build": {
    "asar": true,
    "npmRebuild": false,
    "files": [
      "index.js",
      "preload.js",
      "server/**/*",
      "util/**/*",
      "config.txt",
      "logo.ico",
      "build/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "db",
        "to": "db"
      },
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "icon": "./logo",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "sqlite3",
      "@serialport/bindings-cpp"
    ]
  }
}
